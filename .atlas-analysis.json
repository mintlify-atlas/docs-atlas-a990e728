    "graq phantom browse|audit|discover|flow",
    "graq doctor",
    "graq plugins list|install",
    "Graqle (Python class — core graph object)",
    "CogniNode (graph node)",
    "CogniEdge (graph edge)",
    "Message (inter-agent message)",
    "ReasoningResult (query result with confidence, cost, latency)",
    "GraqleConfig (YAML config loader)"
  ]
